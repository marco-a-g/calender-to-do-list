{
    "name": "Planify-Desktop-Dev",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "containerEnv": {
        // Host DISPLAY übernehmen (z. B. :0, :1 oder :99), statt hart :0 zu erzwingen.
        "DISPLAY": "${localEnv:DISPLAY}",
        "XAUTHORITY": "/home/vscode/.Xauthority",
        "GDK_BACKEND": "x11",
        "WEBKIT_DISABLE_COMPOSITING_MODE": "1",
        "LIBGL_ALWAYS_SOFTWARE": "1"
    },
    "runArgs": [
        "--net=host",
        "--privileged",
        // Der einzige, saubere Mount-Punkt für die Grafik-Schnittstelle
        "-v", "/tmp/.X11-unix:/tmp/.X11-unix",
        // X11-Authentifizierung aus der Host-Session bereitstellen
        "-v", "${localEnv:HOME}/.Xauthority:/home/vscode/.Xauthority:ro"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "rust-lang.rust-analyzer",
                "tamasfe.even-better-toml"
            ]
        }
    },
    "remoteUser": "vscode"
}